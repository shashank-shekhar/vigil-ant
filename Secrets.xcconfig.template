// Secrets.xcconfig — Copy this to Secrets.xcconfig and fill in your values
// Register a GitHub App at: https://github.com/settings/apps
// Enable "Device Flow" in your GitHub App settings
CLIENT_ID = YOUR_CLIENT_ID_HERE

// Generate with: ./scripts/generate-sparkle-keys.sh
// The public key goes here; the private key goes in CI secrets as SPARKLE_PRIVATE_KEY
SPARKLE_PUBLIC_KEY = YOUR_EDDSA_PUBLIC_KEY_HERE
